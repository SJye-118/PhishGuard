# ─────────────────────────────────────────────────────────────────
# PhishGuard Enterprise — Environment Configuration Template
# Copy this file to .env and populate the values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────

# ── Redis ────────────────────────────────────────────────────────
# Local Docker Compose: redis://redis:6379
# Upstash free tier:    rediss://:password@host:port
REDIS_URL=redis://localhost:6379

# ── Model ────────────────────────────────────────────────────────
# Path to the serialised scikit-learn model inside the container.
# Run `dvc pull artefacts/phishguard_model.joblib` to download.
MODEL_PATH=./artefacts/phishguard_model.joblib

# ── Brand Protection ─────────────────────────────────────────────
# Number of top Tranco domains loaded as the brand keyword list.
# Range: 100–10000. Default: 1000.
BRAND_LIST_SIZE=1000

# ── Logging ──────────────────────────────────────────────────────
# Verbosity level. Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── URL Validation ───────────────────────────────────────────────
# Maximum URL string length accepted by the API.
MAX_URL_LENGTH=2048

# ── Network Timeouts (milliseconds) ──────────────────────────────
# Hard timeout for RDAP domain registration queries.
RDAP_TIMEOUT_MS=1500

# Hard timeout for TLS/SSL certificate inspection.
SSL_TIMEOUT_MS=1500

# ── Redis Cache ───────────────────────────────────────────────────
# TTL in seconds for cached classification results. Default: 24 hours.
CACHE_TTL_SECONDS=86400

# ── Veto Logic ───────────────────────────────────────────────────
# Domain age (days) below which the veto condition becomes evaluable.
# A domain younger than this AND with a brand keyword match triggers
# an unconditional CRITICAL override.
VETO_AGE_THRESHOLD_DAYS=14

# ── Application ───────────────────────────────────────────────────
# Semantic version string displayed in /health and API metadata.
APP_VERSION=1.0.0

# Runtime environment. Options: development | staging | production
# Controls CORS policy and log verbosity defaults.
ENVIRONMENT=development

# ── Optional Integrations ─────────────────────────────────────────
# Sentry error tracking DSN. Leave blank to disable.
# SENTRY_DSN=

# API key hashing salt (Phase 2 — leave blank for Phase 1).
# API_KEY_SALT=